{
  "version": 2,
  "builds": [
    {
      "src": "server.py",
      "use": "@vercel/python"
    },
    {
      "src": "*.{html,js,css}",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/solve",
      "dest": "/server.py"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/dashboard.html",
      "dest": "/dashboard.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
